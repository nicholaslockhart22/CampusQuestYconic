{
  "name": "campusquest-yconic",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:api": "node services/api/src/server.js",
    "dev:mobile": "node apps/mobile/dev-server.js",
    "dev:admin": "node apps/admin/dev-server.js",
    "dev:web": "npm --workspace @campusquest/web run dev",
    "start": "node services/api/src/prod-server.js",
    "start:prod": "node services/api/src/prod-server.js",
    "test": "node --test",
    "test:api": "node --test services/api/test/*.test.js",
    "smoke:test": "bash scripts/smoke-test.sh"
  }
}
